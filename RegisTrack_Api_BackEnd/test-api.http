}

###############################################
# COMPLEX WORKFLOW TEST
###############################################

### 54. Complete workflow: Create user, document type, requirement, and request
### Step 1: Create student
POST {{baseUrl}}/Users
Content-Type: application/json

{
  "firstName": "Maria",
  "lastName": "Santos",
  "email": "maria.santos@aclc.edu.ph",
  "studentId": "STU-2024-100",
  "password": "MariaPass123!",
  "role": "Student"
}

### Step 2: Create document type
POST {{baseUrl}}/DocumentTypes
Content-Type: application/json

{
  "name": "Certificate of Good Moral",
  "description": "Certificate attesting to good moral character",
  "processingFee": 100.00,
  "processingDays": 3
}

### Step 3: Add requirements
POST {{baseUrl}}/DocumentRequirements
Content-Type: application/json

{
  "documentTypeId": 4,
  "requirementName": "Clearance Form",
  "description": "Fully cleared from all departments",
  "isMandatory": true,
  "displayOrder": 1
}

### Step 4: Create request
POST {{baseUrl}}/DocumentRequests
Content-Type: application/json

{
  "userId": 3,
  "documentTypeId": 4,
  "purpose": "Transfer to another institution",
  "quantity": 1,
  "notes": "Needed urgently for enrollment deadline"
}

### Step 5: Process the request through all statuses
# (Use the reference number from Step 4 response)
